COMPOSE_PROJECT_NAME=bloggent
SERVICE_ENV_FILE=.env
PROJECT_NAME=Bloggent
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg2://bloggent:bloggent@postgres:5432/bloggent
REDIS_URL=redis://redis:6379/0
PUBLIC_API_BASE_URL=http://localhost:8000
PUBLIC_WEB_BASE_URL=http://localhost:3001
STORAGE_ROOT=/app/storage
PUBLIC_IMAGE_PROVIDER=cloudflare_r2
PUBLIC_ASSET_BASE_URL=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
CLOUDFLARE_R2_PREFIX=assets/images
GITHUB_PAGES_OWNER=
GITHUB_PAGES_REPO=
GITHUB_PAGES_BRANCH=main
GITHUB_PAGES_TOKEN=
GITHUB_PAGES_BASE_URL=
GITHUB_PAGES_ASSETS_DIR=assets/images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=bloggent
SCHEDULE_TIME=09:00
SCHEDULE_TIMEZONE=Asia/Seoul
SCHEDULE_ENABLED=true
DEFAULT_PUBLISH_MODE=draft
PROVIDER_MODE=mock
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_REQUEST_SAVER_MODE=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_DAILY_REQUEST_LIMIT=6
GEMINI_REQUESTS_PER_MINUTE_LIMIT=2
PIPELINE_STOP_AFTER=none
BLOGGER_CLIENT_NAME=
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=
BLOGGER_REDIRECT_URI=
BLOGGER_REFRESH_TOKEN=
BLOGGER_ACCESS_TOKEN_EXPIRES_AT=
BLOGGER_TOKEN_SCOPE=
BLOGGER_TOKEN_TYPE=Bearer
BLOGGER_OAUTH_STATE=
BLOGGER_ACCESS_TOKEN=
BLOGGER_BLOG_ID=
YOUTUBE_DEFAULT_PRIVACY_STATUS=private
META_GRAPH_API_VERSION=v23.0
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_PUBLISH_API_ENABLED=false
API_STORAGE_DIR=./storage
POSTGRES_DATA_DIR=./.docker-data/postgres
REDIS_DATA_DIR=./.docker-data/redis
MINIO_DATA_DIR=./.docker-data/minio
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SEED_DEMO_DATA=true
AUTO_TRIGGER_ON_DISCOVERY=true
RELATED_POST_COUNT=3
# required: secret settings storage will fail fast when this is empty
SETTINGS_ENCRYPTION_SECRET=change-this-local-secret
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MARKETING_HERO_URL=
API_INTERNAL_URL=http://api:8000/api/v1
API_PORT=8000
POSTGRES_PORT=5432
WEB_PORT=3001
